{
  "expo": {
    "name": "Refuge Worldwide",
    "slug": "refuge-worldwide",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "refugeworldwideapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "preview": {
      "distribution": "internal"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4AFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.refuge-worldwide-app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.refugeworldwide.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A4AFC",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#1A4AFC"
          }
        }
      ],
      "expo-audio",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d4bfa8e-3c8f-47f9-81ef-c387cbe0559a"
      }
    }
  }
}
